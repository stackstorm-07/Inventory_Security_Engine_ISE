{
  "version": 2,
  "builds": {
    "frontend": {
      "source": "frontend/",
      "use": "@vercel/static"
    },
    "backend": {
      "source": "backend/",
      "use": "@vercel/node"
    }
  },
  "routes": [
    {
      "src": "frontend/index.html",
      "dest": "index.html"
    },
    {
      "src": "frontend/dashboard.html",
      "dest": "dashboard.html"
    },
    {
      "src": "frontend/security-alerts.html",
      "dest": "security-alerts.html"
    },
    {
      "src": "frontend/admin-orders.html",
      "dest": "admin-orders.html"
    },
    {
      "src": "frontend/access-control.html",
      "dest": "access-control.html"
    },
    {
      "src": "frontend/reports.html",
      "dest": "reports.html"
    },
    {
      "src": "frontend/inventory-logs.html",
      "dest": "inventory-logs.html"
    }
  ],
  "env": {
    "API_BASE_URL": "@vercel-backend-url"
  }
}
